# ─── YieldFarmer AI — Environment Variables ───
#
# Quick Start:
#   1. Copy this file:   cp .env.example .env
#   2. Fill in your API keys below
#   3. Start services:   ./start.sh   OR   docker compose up -d
#
# ── Docker users ──
#   docker compose reads .env automatically.
#   The frontend's NEXT_PUBLIC_API_URL is set inside docker-compose.yml
#   (http://backend:8000) — no need to configure it here.
#
# ── Non-Docker users ──
#   The frontend defaults to http://localhost:8000 for the backend API.
#   Override with NEXT_PUBLIC_API_URL below if your backend runs elsewhere.

# ═══════════════════════════════════════════════
# KeeperHub (REQUIRED)
# ═══════════════════════════════════════════════
# Get your API key: https://app.keeperhub.com → Settings → API Keys
KEEPERHUB_API_KEY=your_keeperhub_api_key_here
KEEPERHUB_API_URL=https://app.keeperhub.com/api

# ═══════════════════════════════════════════════
# LLM Provider — choose ONE of the two below
# ═══════════════════════════════════════════════

# Option A: OpenAI
OPENAI_API_KEY=your-openai-api-key

# Option B: DeepSeek (cheaper for testing, recommended)
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Which model to use (must match the provider whose key you set above)
# deepseek-chat for DeepSeek, gpt-4o for OpenAI
LLM_MODEL=deepseek-chat

# ═══════════════════════════════════════════════
# Blockchain (for demo on testnet)
# ═══════════════════════════════════════════════
CHAIN_ID=11155111                 # 11155111 = Sepolia testnet
RPC_URL=https://sepolia.infura.io/v3/your-infura-key

# ═══════════════════════════════════════════════
# Optional: Telegram notifications
# ═══════════════════════════════════════════════
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ═══════════════════════════════════════════════
# Optional: Frontend API URL (non-Docker only)
# ═══════════════════════════════════════════════
# Default: http://localhost:8000
# NEXT_PUBLIC_API_URL=http://localhost:8000
