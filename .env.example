# KeeperHub Agents Onchain Hackathon — Environment Variables
# Copy this to .env and fill in your values

# KeeperHub
KEEPERHUB_API_KEY=your_keeperhub_api_key_here
KEEPERHUB_API_URL=https://app.keeperhub.com/api

# LLM Provider (choose one)
OPENAI_API_KEY=sk-your-openai-key
# or use DeepSeek (cheaper for testing)
DEEPSEEK_API_KEY=your-deepseek-key
DEEPSEEK_BASE_URL=https://api.deepseek.com

# LLM Model
LLM_MODEL=deepseek-chat
# LLM_MODEL=gpt-4o

# Blockchain (for demo on testnet)
CHAIN_ID=11155111  # Sepolia
RPC_URL=https://sepolia.infura.io/v3/your-key

# Telegram notifications (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
